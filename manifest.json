{
  "manifest_version": 3,
  "name": "URL Auto Refresher",
  "version": "0.1.0",
  "description": "Scheduled refreshes to a target URL per tab with optional sync groups and jitter.",
  "permissions": ["storage", "alarms", "tabs", "windows", "sidePanel"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_title": "URL Auto Refresher — open dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_ui": {
    "page": "dashboard/dashboard.html",
    "open_in_tab": true
  }
}
