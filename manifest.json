{
  "manifest_version": 3,
  "name": "URL Auto Refresher",
  "version": "0.16.4",
  "description": "Scheduled refreshes to a target URL per tab with optional global synchronized groups, individuals, and jitter.",
  "permissions": ["storage", "alarms", "tabs", "windows", "sidePanel", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_title": "URL Auto Refresher — open side panel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "options_ui": {
    "page": "dashboard/dashboard.html",
    "open_in_tab": true
  },
  "commands": {
    "volume-up": {
      "suggested_key": {
        "default": "Ctrl+Shift+Up",
        "mac": "Command+Shift+Up"
      },
      "description": "Increase precision media volume on the active tab"
    },
    "volume-down": {
      "suggested_key": {
        "default": "Ctrl+Shift+Down",
        "mac": "Command+Shift+Down"
      },
      "description": "Decrease precision media volume on the active tab"
    },
    "panic-mute": {
      "suggested_key": {
        "default": "Ctrl+Shift+0",
        "mac": "Command+Shift+0"
      },
      "description": "Panic mute media volume on the active tab"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/page-overlay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.twitch.tv/*", "https://twitch.tv/*"],
      "js": ["dist/twitch-live-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
