{
  "name": "url-auto-refresher",
  "version": "0.2.1",
  "private": true,
  "description": "Edge MV3 extension: scheduled tab refreshes with global groups and individuals",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:lib": "vitest run --coverage --coverage.include=src/lib/**/*.ts --coverage.exclude=**/*.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headless": "node e2e/run-playwright-headless.mjs",
    "build": "node Scripts/build.mjs && node Scripts/gen-icons.mjs",
    "build:icons": "node Scripts/gen-icons.mjs",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run lint && npm run format:check && npm test && npm run build && npm run test:e2e",
    "ci:watch-gh": "node Scripts/watch-gh-ci.mjs",
    "push:main": "node Scripts/push-main-watch-ci.mjs",
    "prepare": "husky && node Scripts/install-git-push-alias.mjs"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{json,md,yml,yaml,css,html}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.268",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.0.0"
  }
}
