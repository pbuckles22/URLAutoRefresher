{
  "name": "url-auto-refresher",
  "version": "0.1.0",
  "private": true,
  "description": "Edge MV3 extension: scheduled tab refreshes with global groups and individuals",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:lib": "vitest run --coverage --coverage.include=src/lib/**/*.ts --coverage.exclude=**/*.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "build": "node Scripts/build.mjs && node Scripts/gen-icons.mjs",
    "build:icons": "node Scripts/gen-icons.mjs",
    "ci": "npm test && npm run build && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.268",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
